---
/**
 * Footer Component - AJOA Arquitectura
 */

import Logo from './Logo.astro';

interface Props {
  variant?: 'boxed' | 'fullWidth';
}

const { variant = 'boxed' } = Astro.props;

const footerLinks = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#contacto', label: 'Contacto' },
];

const socialLinks = [
  {
    href: 'https://www.instagram.com/ajoa_arquitectura/',
    label: 'Instagram',
  },
  {
    href: 'https://wa.me/573217432752',
    label: 'WhatsApp',
  },
];

const containerClass =
  variant === 'fullWidth'
    ? 'w-full px-4'
    : 'container max-w-7xl mx-auto px-4 sm:px-6';
---

<footer class="border-t border-border/60 bg-background">
  <div class:list={[containerClass, 'py-12']}>
    <div class="grid gap-10 md:grid-cols-[1.4fr_0.8fr_0.8fr]">
      <!-- Brand -->
      <div>
        <Logo />

        <p class="mt-5 max-w-md text-sm leading-relaxed text-muted-foreground">
          Diseñamos y construimos proyectos residenciales, comerciales y rurales,
          integrando arquitectura, visualización 3D y acompañamiento constructivo.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="mb-4 font-semibold">Navegación</h3>

        <ul class="space-y-2">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="mb-4 font-semibold">Contacto</h3>

        <ul class="space-y-2">
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <p class="mt-4 text-sm text-muted-foreground">
          Cotizaciones: +57 321 743 2752
        </p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-10 border-t border-border/60 pt-8 text-center text-sm text-muted-foreground">
      <p>
        &copy; {new Date().getFullYear()} AJOA Arquitectura. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>