---
/**
 * Hero Section - AJOA Arquitectura
 */

interface Props {
  title?: string;
  subtitle?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  badge?: string;
  image?: string;
}

const {
  title = "Diseñamos y construimos espacios con propósito",
  subtitle = "En AJOA Arquitectura transformamos ideas en proyectos reales, combinando diseño arquitectónico, visualización 3D y construcción para crear espacios modernos, funcionales y llenos de identidad.",
  primaryCta = { href: "#contacto", label: "Cotizar proyecto" },
  secondaryCta = { href: "#proyectos", label: "Ver proyectos" },
  badge = "Arquitectura · Diseño · Construcción",
  image = "/images/ajoa-hero.png"
} = Astro.props;

const gridSize = 46;
const squareSize = 14;
const gap = 2;

const seededRandom = (x: number, y: number): number => {
  const seed = x * 1000 + y;
  const a = Math.sin(seed * 12.9898 + seed * 78.233) * 43758.5453;
  return a - Math.floor(a);
};

const getArchitecturalIntensity = (x: number, y: number): number => {
  const centerX = gridSize / 2;
  const centerY = gridSize / 2;

  const dx = x - centerX;
  const dy = y - centerY;
  const distance = Math.sqrt(dx * dx + dy * dy);

  const verticalLines = x % 8 === 0 ? 1.5 : 0;
  const horizontalLines = y % 7 === 0 ? 1.2 : 0;
  const diagonalDetail = Math.abs(x - y) % 13 === 0 ? 1 : 0;

  const randomFactor = seededRandom(x, y) * 0.8;
  const fadeFactor = Math.max(0, 1 - distance / (gridSize / 1.8));

  const combined =
    (verticalLines + horizontalLines + diagonalDetail + randomFactor) *
    fadeFactor;

  return Math.floor(Math.min(4, combined));
};

const rects: Array<{ x: number; y: number; opacity: number }> = [];

for (let y = 0; y < gridSize; y++) {
  for (let x = 0; x < gridSize; x++) {
    const intensity = getArchitecturalIntensity(x, y);

    if (intensity > 0) {
      rects.push({
        x: x * (squareSize + gap),
        y: y * (squareSize + gap),
        opacity: intensity * 0.14
      });
    }
  }
}

const svgWidth = gridSize * (squareSize + gap);
const svgHeight = gridSize * (squareSize + gap);
---

<section class="relative min-h-[90vh] overflow-hidden bg-[#111111] text-white">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(245,158,11,0.18),transparent_32%),linear-gradient(135deg,#111111_0%,#1c1c1c_45%,#050505_100%)]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-transparent to-black/70"></div>
  </div>

  <div class="pointer-events-none absolute inset-0 z-0 flex items-center justify-center opacity-30">
    <svg
      width={svgWidth}
      height={svgHeight}
      viewBox={`0 0 ${svgWidth} ${svgHeight}`}
      xmlns="http://www.w3.org/2000/svg"
      class="text-white"
      aria-hidden="true"
    >
      {rects.map((rect) => (
        <rect
          x={rect.x}
          y={rect.y}
          width={squareSize}
          height={squareSize}
          rx="2"
          fill="currentColor"
          opacity={rect.opacity}
        />
      ))}
    </svg>
  </div>

  <div class="container relative z-10 mx-auto grid min-h-[90vh] max-w-7xl items-center gap-14 px-6 py-24 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="max-w-3xl">
      {badge && (
        <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-white/15 bg-white/10 px-5 py-2 text-sm font-medium text-white shadow-2xl backdrop-blur-md">
          <span class="h-2 w-2 rounded-full bg-amber-400"></span>
          <span>{badge}</span>
        </div>
      )}

      <h1 class="max-w-4xl text-5xl font-bold leading-[0.95] tracking-tight md:text-7xl lg:text-8xl">
        {title}
      </h1>

      <p
        class="mt-7 max-w-2xl text-lg leading-relaxed text-white/75 md:text-xl"
        set:html={subtitle}
      />

      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        {primaryCta && (
          <a
            href={primaryCta.href}
            class="group relative inline-flex h-14 items-center justify-center overflow-hidden rounded-full bg-amber-400 px-9 text-base font-semibold text-neutral-950 shadow-xl shadow-amber-500/20 transition-all duration-300 hover:scale-105 hover:bg-amber-300"
          >
            <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/60 to-transparent transition-transform duration-700 group-hover:translate-x-full"></span>
            <span class="relative z-10">{primaryCta.label}</span>
          </a>
        )}

        {secondaryCta && (
          <a
            href={secondaryCta.href}
            class="inline-flex h-14 items-center justify-center rounded-full border border-white/25 bg-white/10 px-9 text-base font-semibold text-white backdrop-blur-md transition-all duration-300 hover:bg-white hover:text-neutral-950"
          >
            {secondaryCta.label}
          </a>
        )}
      </div>

      <div class="mt-14 grid max-w-2xl grid-cols-2 gap-6 border-t border-white/15 pt-8 md:grid-cols-3">
        <div>
          <p class="text-3xl font-bold">217+</p>
          <p class="mt-1 text-sm text-white/55">Proyectos publicados</p>
        </div>

        <div>
          <p class="text-3xl font-bold">3600+</p>
          <p class="mt-1 text-sm text-white/55">Personas conectadas</p>
        </div>

        <div>
          <p class="text-3xl font-bold">360°</p>
          <p class="mt-1 text-sm text-white/55">Diseño y construcción</p>
        </div>
      </div>
    </div>

    <div class="relative mx-auto w-full max-w-xl lg:max-w-none">
      <div class="absolute -left-6 -top-6 h-32 w-32 rounded-full bg-amber-400/20 blur-3xl"></div>
      <div class="absolute -bottom-10 -right-10 h-44 w-44 rounded-full bg-white/10 blur-3xl"></div>

      <div class="relative overflow-hidden rounded-[2rem] border border-white/15 bg-white/10 p-3 shadow-2xl backdrop-blur-md">
        <div class="relative overflow-hidden rounded-[1.5rem]">
          <img
            src={image}
            alt="Proyecto arquitectónico desarrollado por AJOA Arquitectura"
            class="h-[520px] w-full object-cover transition-transform duration-700 hover:scale-105"
          />

          <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>

          <div class="absolute bottom-6 left-6 right-6">
            <p class="text-sm font-medium uppercase tracking-[0.3em] text-amber-300">
              Proyecto destacado
            </p>
            <h2 class="mt-2 text-3xl font-bold">
              Diseño residencial y comercial
            </h2>
            <p class="mt-2 max-w-md text-sm leading-relaxed text-white/70">
              Propuestas arquitectónicas modernas con enfoque funcional, visualización previa y acompañamiento constructivo.
            </p>
          </div>
        </div>
      </div>

      <div class="absolute -left-4 top-10 hidden rounded-2xl border border-white/15 bg-white/90 px-5 py-4 text-neutral-950 shadow-xl backdrop-blur-md md:block">
        <p class="text-sm font-semibold">Visualización 3D</p>
        <p class="mt-1 text-xs text-neutral-600">Renders para ver antes de construir</p>
      </div>

      <div class="absolute -right-4 bottom-20 hidden rounded-2xl border border-white/15 bg-neutral-950/85 px-5 py-4 text-white shadow-xl backdrop-blur-md md:block">
        <p class="text-sm font-semibold">Diseño + Construcción</p>
        <p class="mt-1 text-xs text-white/60">Acompañamiento integral</p>
      </div>
    </div>
  </div>
</section>