---
/**
 * Logo Component
 *
 * AstroDeck brand logo with card deck icon and wordmark.
 * Used consistently across Header, Footer, and Auth layouts.
 *
 * @example
 * ```astro
 * <Logo />
 * <Logo showText={false} />
 * <Logo size="lg" />
 * ```
 */
interface Props {
  /** Show the "AstroDeck" text next to the icon */
  showText?: boolean;
  /** Size variant */
  size?: 'sm' | 'md' | 'lg';
  /** Additional CSS classes */
  class?: string;
}

const { showText = true, size = 'md', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'h-5 w-5',
  md: 'h-6 w-6',
  lg: 'h-8 w-8',
};

const textSizeClasses = {
  sm: 'text-sm',
  md: 'text-base',
  lg: 'text-lg',
};
---

<a href="/" class="inline-flex items-center gap-3 font-bold text-foreground">
  <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-neutral-950 text-white dark:bg-white dark:text-neutral-950">
    <span class="text-sm font-black tracking-tight">A</span>
  </div>

  <div class="leading-none">
    <span class="block text-base font-bold tracking-tight">
      AJOA
    </span>
    <span class="block text-[10px] font-medium uppercase tracking-[0.22em] text-muted-foreground">
      Arquitectura
    </span>
  </div>
</a>
