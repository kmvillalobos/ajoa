---
import BaseLayout from "@/layouts/BaseLayout.astro";

const releases = [
  {
    version: "2.0.3",
    date: "2026-03-15",
    tag: "patch",
    title: "Documentation Page, Navigation Overhaul & Design Tokens",
    highlights: [
      "New /docs page with AI-first two-column layout — every task shown as AI prompt and manual steps side by side",
      "9 documentation sections: Getting Started, Pages, Sections, Components, Theme, Design Tokens, Blog, Deploy, Structure",
      "Design Tokens reference table with all CSS variables and their Tailwind utility classes",
      "Mobile collapsible 'On this page' sub-navigation for /docs and /sections pages",
      "Header dropdown menu: Blog, Content, and Login grouped under 'Pages'",
      "Active page highlighting in main navigation with aria-current support",
      "Responsive design skill added to agent and QA/UI-design skills with breakpoint checklists",
    ],
  },
  {
    version: "2.0.2",
    date: "2026-03-15",
    tag: "patch",
    title: "Self-Improving Skill System & Quality Fixes",
    highlights: [
      "Added 6 domain skills (ui-design, tailwind, astro, accessibility, qa, content-seo) with KPIs and self-improving learnings",
      "New /launch-check command for production-readiness checks across all Lighthouse categories",
      "Fixed ESLint errors, TypeScript errors, inline styles, hardcoded colors, and design inconsistencies",
      "Footer updated with templatedeck.com link",
    ],
  },
  {
    version: "2.0.1",
    date: "2026-03-14",
    tag: "patch",
    title: "Changelog Page",
    highlights: [
      "New Changelog page with timeline design showing all releases at a glance",
      "Changelog added to main navigation",
    ],
  },
  {
    version: "2.0.0",
    date: "2026-03-14",
    tag: "major",
    title: "Astro 6.0 + Vite 7",
    highlights: [
      "Upgraded to Astro 6.0 with Vite 7 — faster dev server with unified dev/production code paths",
      "Node.js 22+ now required (dropped Node 18/20)",
      "Migrated view transitions from ViewTransitions to ClientRouter",
      "All AI tooling (agents, commands, docs) updated for Astro 6",
      "Added comprehensive CHANGELOG with full release history",
    ],
    breaking: [
      "Node.js 22+ required",
      "Zod imports moved from astro:content to astro/zod",
      "ViewTransitions renamed to ClientRouter",
    ],
  },
  {
    version: "1.5.2",
    date: "2026-03-12",
    tag: "patch",
    title: "Dark Mode Architecture",
    highlights: [
      "Refactored dark mode system for better theme persistence",
      "Fixed TypeScript error with querySelectorAll generics",
    ],
  },
  {
    version: "1.5.1",
    date: "2026-01-27",
    tag: "patch",
    title: "Contrast Improvements",
    highlights: [
      "Improved muted-foreground contrast in light mode",
      "Dark mode contrast improvements and theme persistence fix",
    ],
  },
  {
    version: "1.5.0",
    date: "2026-01-26",
    tag: "minor",
    title: "Copy-Code Buttons",
    highlights: [
      "Added functional copy-code buttons to the sections showcase page",
      "Updated all dependencies with security fixes",
    ],
  },
  {
    version: "1.4.0",
    date: "2025-12-27",
    tag: "minor",
    title: "Content Layer API",
    highlights: [
      "Migrated to Content Layer API for future Astro compatibility",
    ],
  },
  {
    version: "1.3.0",
    date: "2025-12-26",
    tag: "minor",
    title: "SEO & Layouts",
    highlights: [
      "Added MinimalLayout for standalone pages (404, maintenance, landing)",
      "Comprehensive SEO support: OpenGraph, Twitter Cards, canonical URLs, sitemap, RSS",
      "Responsive header with hamburger menu and accessibility improvements",
      "Added PROJECT.md for user-specific AI instructions",
    ],
  },
  {
    version: "1.2.0",
    date: "2025-12-25",
    tag: "minor",
    title: "Claude Code Agent",
    highlights: [
      "Introduced Claude Code AI Agent for intelligent project assistance",
      "Added AI feature section to homepage with tools grid",
      "Consolidated AI guidelines into the AGENTS.md standard",
    ],
  },
  {
    version: "1.1.0",
    date: "2025-12-23",
    tag: "minor",
    title: "AI-Friendly & Tailwind v4",
    highlights: [
      "Added AGENTS.md — AI-friendly development documentation",
      "Migrated to Tailwind CSS v4 with @tailwindcss/vite plugin",
      "Vercel Analytics integration",
      "Redesigned features section and footer",
    ],
  },
  {
    version: "1.0.0",
    date: "2025-12-21",
    tag: "major",
    title: "Initial Release",
    highlights: [
      "15+ pre-built sections: Hero, CTA, Features, Pricing, Testimonials, Newsletter, and more",
      "4 layout templates: Base, Full-Width, Auth, and Minimal",
      "shadcn/ui components with Radix UI primitives",
      "Dark mode with theme persistence",
      "Blog system with Content Collections",
      "Full TypeScript support with ESLint and Prettier",
    ],
  },
];

const tagStyles: Record<string, { bg: string; text: string; label: string }> = {
  major: { bg: "bg-primary", text: "text-primary-foreground", label: "Major" },
  minor: { bg: "bg-foreground/10 border border-foreground/20", text: "text-foreground", label: "Minor" },
  patch: { bg: "bg-foreground/5 border border-foreground/15", text: "text-muted-foreground", label: "Patch" },
};
---

<BaseLayout
  title="Changelog"
  description="See what's new in AstroDeck — all releases, features, and improvements at a glance."
>
  <div class="container max-w-3xl mx-auto py-16 px-6">
    <header class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
        Changelog
      </h1>
      <p class="text-lg text-muted-foreground">
        New features, improvements, and fixes in every AstroDeck release.
      </p>
    </header>

    <!-- Timeline -->
    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-[7px] top-2 bottom-0 w-px bg-border" aria-hidden="true"></div>

      <div class="space-y-12">
        {releases.map((release, index) => (
          <article class:list={["relative pl-10", index === 0 && "rounded-xl border bg-card p-6 -ml-2 pl-12"]}>
            <!-- Timeline dot -->
            <div
              class:list={[
                "absolute top-2 w-[15px] h-[15px] rounded-full border-2 border-background",
                index === 0 ? "left-[-2px] lg:left-[-9px] bg-primary ring-4 ring-primary/20" : "left-0",
                index !== 0 && (release.tag === "major" ? "bg-primary" : "bg-muted-foreground/40"),
              ]}
              aria-hidden="true"
            />

            <!-- Version header -->
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h2 class="text-2xl font-bold">v{release.version}</h2>
              {index === 0 && (
                <span class="px-2 py-0.5 rounded-md text-xs font-semibold bg-primary text-primary-foreground">
                  Latest
                </span>
              )}
              <span
                class:list={[
                  "px-2 py-0.5 rounded-md text-xs font-semibold",
                  tagStyles[release.tag].bg,
                  tagStyles[release.tag].text,
                ]}
              >
                {tagStyles[release.tag].label}
              </span>
              <time
                datetime={release.date}
                class="text-sm text-muted-foreground"
              >
                {new Date(release.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
            </div>

            <!-- Title -->
            <p class="text-lg font-medium text-foreground/80 mb-4">
              {release.title}
            </p>

            <!-- Breaking changes -->
            {release.breaking && release.breaking.length > 0 && (
              <div class="mb-4 rounded-lg border border-destructive/30 bg-destructive/5 p-4">
                <p class="text-sm font-semibold text-destructive mb-2">Breaking Changes</p>
                <ul class="space-y-1">
                  {release.breaking.map((item) => (
                    <li class="text-sm text-muted-foreground flex items-start gap-2">
                      <span class="text-destructive mt-0.5 shrink-0">!</span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Highlights -->
            <ul class="space-y-2">
              {release.highlights.map((item) => (
                <li class="text-muted-foreground flex items-start gap-2">
                  <svg
                    class="h-5 w-5 text-primary shrink-0 mt-0.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            {index < releases.length - 1 && (
              <div class="mt-8" aria-hidden="true" />
            )}
          </article>
        ))}
      </div>
    </div>

    <!-- Footer CTA -->
    <div class="mt-16 text-center">
      <p class="text-muted-foreground mb-4">
        View the full technical changelog and source code on GitHub.
      </p>
      <a
        href="https://github.com/holger1411/astrodeck/releases"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 justify-center rounded-md bg-primary text-primary-foreground font-medium h-10 px-6 hover:bg-primary/90 transition-colors text-sm"
      >
        All Releases on GitHub
        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  </div>
</BaseLayout>
