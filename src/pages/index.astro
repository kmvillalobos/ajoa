---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import Features from "@/components/sections/Features.astro";
import Stats from "@/components/sections/Stats.astro";

const services = [
  {
    title: "Diseño arquitectónico",
    description:
      "Creamos propuestas arquitectónicas personalizadas para viviendas, locales comerciales, proyectos rurales y remodelaciones.",
    icon: "chart",
  },
  {
    title: "Construcción de proyectos",
    description:
      "Acompañamos la ejecución de obra con planificación, criterio técnico y seguimiento profesional para materializar cada diseño.",
    icon: "shield",
  },
  {
    title: "Visualización 3D",
    description:
      "Desarrollamos renders e imágenes realistas que permiten visualizar el proyecto antes de construirlo.",
    icon: "zap",
  },
  {
    title: "Proyectos residenciales",
    description:
      "Diseñamos casas modernas, funcionales y adaptadas al estilo de vida de cada familia.",
    icon: "users",
  },
  {
    title: "Proyectos comerciales",
    description:
      "Diseñamos espacios comerciales con identidad, presencia visual y funcionalidad para potenciar negocios e inversiones.",
    icon: "globe",
  },
  {
    title: "Remodelaciones y adecuaciones",
    description:
      "Transformamos espacios existentes para mejorar su distribución, estética, funcionalidad y valor.",
    icon: "lock",
  },
];
---

<BaseLayout
  title="AJOA Arquitectura | Diseño y construcción de espacios"
  description="AJOA Arquitectura diseña y construye proyectos residenciales, comerciales y rurales, integrando arquitectura, visualización 3D y acompañamiento constructivo."
>
  <Hero
    badge="Arquitectura · Diseño · Construcción"
    title="Diseñamos y construimos espacios con propósito"
    subtitle="En AJOA Arquitectura transformamos ideas en proyectos reales, combinando diseño arquitectónico, visualización 3D y construcción para crear espacios modernos, funcionales y llenos de identidad."
    primaryCta={{ href: "#contacto", label: "Cotizar proyecto" }}
    secondaryCta={{ href: "#proyectos", label: "Ver proyectos" }}
    image="/images/ajoa-hero.png"
  />

  <div class="section-inverted py-8">
    <Stats
      stats={[
        {
          value: "217+",
          label: "Publicaciones",
          description: "Proyectos, avances y diseños compartidos",
        },
        {
          value: "3600+",
          label: "Comunidad",
          description: "Personas conectadas con nuestro trabajo",
        },
        {
          value: "360°",
          label: "Servicio integral",
          description: "Diseño, visualización y construcción",
        },
        {
          value: "100%",
          label: "Personalizado",
          description: "Cada proyecto se adapta a cada cliente",
        },
      ]}
    />
  </div>

  <section id="servicios">
    <Features
      title="Soluciones arquitectónicas para cada tipo de proyecto"
      subtitle="Diseñamos espacios residenciales, comerciales y rurales con una visión moderna, funcional y cuidadosamente planificada."
      features={services}
    />
  </section>

  <div class="section-inverted">
    <section class="px-6 py-20 md:py-32">
      <div class="container mx-auto max-w-6xl">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <div data-animate="fade-up">
            <span class="text-sm font-semibold uppercase tracking-[0.3em] text-primary">
              Nuestra esencia
            </span>

            <h2 class="mt-4 text-3xl font-bold leading-tight md:text-5xl">
              Arquitectura pensada para vivir, invertir y construir mejor
            </h2>

            <p class="mt-6 text-lg leading-relaxed text-muted-foreground">
              En AJOA Arquitectura creemos que cada proyecto debe iniciar con una buena idea,
              una planeación clara y una ejecución cuidadosa. Por eso acompañamos a nuestros
              clientes desde la conceptualización del diseño hasta la visualización y desarrollo
              del proyecto.
            </p>

            <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
              Nuestro enfoque combina estética contemporánea, funcionalidad, identidad visual y
              soluciones constructivas viables para crear espacios que respondan a las necesidades
              reales de cada cliente.
            </p>
          </div>

          <div class="relative overflow-hidden rounded-3xl border bg-background shadow-xl" data-animate="scale">
            <img
              src="/images/ajoa-hero.png"
              alt="Proyecto arquitectónico destacado de AJOA Arquitectura"
              class="h-[460px] w-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>
  </div>

  <section id="proyectos" class="px-6 py-20 md:py-32">
    <div class="container mx-auto max-w-6xl">
      <div class="mx-auto max-w-3xl text-center" data-animate="fade-up">
        <span class="text-sm font-semibold uppercase tracking-[0.3em] text-primary">
          Proyectos destacados
        </span>

        <h2 class="mt-4 text-3xl font-bold leading-tight md:text-5xl">
          Espacios con diseño, identidad y funcionalidad
        </h2>

        <p class="mt-6 text-lg leading-relaxed text-muted-foreground">
          Desarrollamos proyectos residenciales, comerciales y rurales, cuidando la imagen,
          la distribución, los materiales y la experiencia de quienes habitan o visitan cada espacio.
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3">
        <article class="overflow-hidden rounded-3xl border bg-background shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <img
            src="/images/ajoa-hero.png"
            alt="Paseo Comercial diseñado por AJOA Arquitectura"
            class="h-72 w-full object-cover"
          />
          <div class="p-6">
            <h3 class="text-xl font-bold">Paseo Comercial</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
              Proyecto comercial con fachada moderna, zonas verdes y una imagen arquitectónica
              pensada para atraer visitantes.
            </p>
          </div>
        </article>

        <article class="overflow-hidden rounded-3xl border bg-background shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <img
            src="/images/ajoa-hero.png"
            alt="Casa rural diseñada por AJOA Arquitectura"
            class="h-72 w-full object-cover"
          />
          <div class="p-6">
            <h3 class="text-xl font-bold">Casa Rural Los Potrillos</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
              Diseño campestre cálido y contemporáneo, conectado con el entorno natural y pensado
              para el descanso.
            </p>
          </div>
        </article>

        <article class="overflow-hidden rounded-3xl border bg-background shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <img
            src="/images/ajoa-hero.png"
            alt="Vivienda moderna diseñada por AJOA Arquitectura"
            class="h-72 w-full object-cover"
          />
          <div class="p-6">
            <h3 class="text-xl font-bold">Vivienda moderna</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
              Espacios residenciales funcionales, bien iluminados y adaptados al estilo de vida
              de cada familia.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <div id="contacto" class="section-inverted">
    <section class="px-6 py-20 md:py-32">
      <div class="container mx-auto max-w-3xl text-center" data-animate="scale">
        <h2 class="text-3xl font-bold leading-tight md:text-5xl">
          ¿Tienes una idea para tu próximo proyecto?
        </h2>

        <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-muted-foreground">
          En AJOA Arquitectura te ayudamos a convertirla en un diseño claro, funcional y listo
          para construirse.
        </p>

        <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
          <a
            href="https://wa.me/573217432752"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative inline-flex h-12 items-center justify-center overflow-hidden rounded-md bg-primary px-12 text-base font-semibold text-primary-foreground shadow-lg shadow-primary/30 transition-all duration-300 hover:scale-105 hover:bg-primary/90 hover:shadow-xl hover:shadow-primary/40"
          >
            <span
              class="absolute inset-0 h-full w-full -translate-x-full bg-gradient-to-r from-transparent via-white/30 to-transparent transition-transform duration-700 ease-in-out group-hover:translate-x-full"
              aria-hidden="true"
            ></span>
            <span class="relative z-10 inline-block transition-transform duration-300 group-hover:translate-x-0.5">
              Solicitar cotización
            </span>
          </a>

          <a
            href="https://www.instagram.com/ajoa_arquitectura/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-12 items-center justify-center rounded-md border border-input bg-background px-8 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground"
          >
            Ver Instagram
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>